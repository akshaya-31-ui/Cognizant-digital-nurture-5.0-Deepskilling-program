set SERVEROUTPUT on;
DECLARE
    cursor c_mon_statements IS
        select c.Name,t.TransactionID,t.Amount,t.TransactionType,t.TransactionDate
        from TRANSACTIONS t
        join Accounts a on t.AccountID=a.AccountId
        join Customers c on a.CUSTOMERID=c.CUSTOMERID
        where extract(month from t.TRANSACTIONDATE)=extract(month from sysdate)
        and extract(year from t.TRANSACTIONDATE)=extract(year from sysdate)
        order by c.Name,t.TRANSACTIONDATE;
    v_cur_customer varchar2(100):=null;
begin 
    for stmt_rec in c_mon_statements loop
        if v_cur_customer is null or v_cur_customer!=stmt_rec.Name then
            DBMS_OUTPUT.PUT_LINE(' Statement for: ' || stmt_rec.Name );
            v_cur_customer := stmt_rec.Name;
        end if;
        DBMS_OUTPUT.PUT_LINE('  TxnID: ' || stmt_rec.TransactionID ||
            ' | ' || stmt_rec.TransactionType ||
            ' | Amount: ' || stmt_rec.Amount ||
            ' | Date: ' || TO_CHAR(stmt_rec.TransactionDate, 'DD-MON-YYYY'));
    end loop;
end;
/

