create or replace procedure UpdateSalary
(
    e_id in number,
    e_percent in NUMBER  
)
is
   e_exist number;
BEGIN
    select count(*) into e_exist
    from Employees
    where EmployeeID=e_id;
    if e_exist=0 THEN
       raise_application_error(-2000,'Employee ID ' || e_id || ' does not exist.');
    end if;
    update Employees
    set Salary=(Salary*e_percent/100)
    where EmployeeID=e_id;
