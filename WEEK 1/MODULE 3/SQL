create or replace PACKAGE AccountOperation 
AS
   PROCEDURE OpenAccount
   (
       p_account_id in number,
       p_customer_id in number,
       p_account_type in VARCHAR2,
       p_balance in number
   );
   PROCEDURE CloseAccount(p_account_id in number);
   FUNCTION GetTotalBalance(p_customer_id in number) return number;
end AccountOperation;
/
create or replace PACKAGE BODY AccountOperation
AS
   PROCEDURE OpenAccount
   (
       p_account_id in number,
       p_customer_id in number,
       p_account_type in VARCHAR2,
       p_balance in number
   )
   is 
   begin
        insert into Accounts(AccountID,CustomerID,ACCOUNTTYPE,Balance,LASTMODIFIED)
        values (p_account_id,p_customer_id,p_account_type,p_balance,sysdate);
        commit;
        DBMS_OUTPUT.PUT_LINE('Account ' || p_account_id || ' opened for Customer ' || p_customer_id);
   exception
        when DUP_VAL_ON_INDEX then
           DBMS_OUTPUT.PUT_LINE('ERROR: Account ID already exists.');
    end OpenAccount;
    PROCEDURE CloseAccount(p_account_id in number)
    IS
    begin
        delete from Accounts where ACCOUNTID=p_account_id;
        if sql%found then
            commit;
            DBMS_OUTPUT.PUT_LINE('Account ' || p_account_id || ' closed.');
        ELSE
            DBMS_OUTPUT.PUT_LINE('ERROR: Account not found.');
        end if;
    end CloseAccount;
    FUNCTION GetTotalBalance(p_customer_id in number) return number
    IS
      v_total number;
    BEGIN
        select nvl(sum(Balance),0) into v_total
        from ACCOUNTS
        where CustomerID=p_customer_id;
        return v_total;
    end GetTotalBalance;
end AccountOperation;
/
set SERVEROUTPUT on;
BEGIN
    AccountOperation.openAccount(6,1,'Saving',2000);
    DBMS_OUTPUT.PUT_LINE('Total Balnce for Customer 1:' || AccountOperation.GetTotalBalance(1));
    delete from TRANSACTIONS where AccountID=6;
    AccountOperation.CloseAccount(6);
end;
