create or replace TRIGGER CheckTransactionRules
before insert on Transactions
for each ROW
DECLARE
    v_balance number;
BEGIN
    select Balance into v_balance
    from Accounts
    where AccountId=:NEW.AccountID;
    IF :NEW.TransactionType='Deposit' and :NEW.Amount<=0 THEN
        RAISE_APPLICATION_ERROR(-20003,'Deposit amount must be positive');
    end if;
    IF :NEW.TransactionType='Withdrawal' then
        IF :NEW.Amount<= 0 THEN
            RAISE_APPLICATION_ERROR(-20005,'Withdrawal amount must be positive');
        ELSIF :NEW.Amount>v_balance THEN
            RAISE_APPLICATION_ERROR(-20004,'Withdrawal amount exceeds account balance');
        END IF;
    END IF;
end CheckTransactionRules;
