    DBMS_OUTPUT.PUT_LINE('Salary updated successfully for Employee ID: ' || e_id);
exception
    when others then 
       rollback;
       DBMS_OUTPUT.PUT_LINE('ERROR: ' || SQLERRM);
end UpdateSalary;
/
